{
  "entities": {
    "scholarship": {
      "title": "Scholarship",
      "description": "Details about scholarships available for PNS",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "provider": { "type": "string" },
        "accessInfo": { "type": "string" },
        "scheduleStatus": { "type": "string", "enum": ["Buka", "Tutup", "Segera"] },
        "callCenter": { "type": "string" },
        "downloadLink": { "type": "string" },
        "description": { "type": "string" },
        "criteria": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "provider", "scheduleStatus", "description"]
    },
    "registration": {
      "title": "Registration",
      "description": "Scholarship application submission",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "scholarshipId": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "fullName": { "type": "string" },
        "nip": { "type": "string" },
        "rank": { "type": "string" },
        "office": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Disetujui", "Ditolak"] },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["scholarshipId", "userId", "fullName", "nip", "rank", "office"]
    },
    "testimonial": {
      "title": "Testimonial",
      "description": "Video testimonial from scholarship alumni",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "videoUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "videoUrl"]
    },
    "announcement": {
      "title": "Announcement",
      "description": "Latest news and updates for the portal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["Penting", "Berita", "Update"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "type"]
    },
    "quickInfo": {
      "title": "QuickInfo",
      "description": "Short informational cards displayed on the sidebar",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content"]
    }
  },
  "firestore": {
    "/scholarships/{scholarshipId}": {
      "schema": "scholarship",
      "description": "Collection of scholarships"
    },
    "/registrations/{registrationId}": {
      "schema": "registration",
      "description": "Collection of scholarship applications"
    },
    "/testimonials/{testimonialId}": {
      "schema": "testimonial",
      "description": "Collection of video testimonials"
    },
    "/announcements/{announcementId}": {
      "schema": "announcement",
      "description": "Latest news and updates"
    },
    "/quickInfos/{quickInfoId}": {
      "schema": "quickInfo",
      "description": "Informational cards on the sidebar"
    },
    "/admins/{adminId}": {
      "schema": { "type": "object", "properties": { "email": { "type": "string" } } },
      "description": "Authorized admin users"
    }
  }
}
